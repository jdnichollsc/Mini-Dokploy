# Mini-Dokploy environment variables.
# Copy to .env (gitignored) and adjust as needed.

# --- BetterAuth ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# --- App database (SQLite via libsql) ---
# Dev: relative file; stack mode overrides to file:/data/local.db
DATABASE_URL=file:./local.db

# --- Temporal cluster ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=deploy

# --- Temporal image versions (used by docker-compose.yml) ---
POSTGRESQL_VERSION=17-alpine
TEMPORAL_VERSION=1.29.2
TEMPORAL_ADMINTOOLS_VERSION=1.29.1-tctl-1.18.4-cli-1.5.0
TEMPORAL_UI_VERSION=2.44.1

# --- AI (optional; feature-flags AI activities) ---
ANTHROPIC_API_KEY=

# --- Build / log workspace ---
DOKPLOY_LOG_DIR=./.dokploy-logs
DOKPLOY_BUILD_DIR=./.dokploy-builds
DOKPLOY_OVERLAY=dokploy-network
DOKPLOY_HOST_SUFFIX=127.0.0.1.sslip.io
