{
  "name": "@mini-dokploy/db",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "@mini-dokploy/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mini-dokploy/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.22.3",
    "typescript": "catalog:"
  }
}
